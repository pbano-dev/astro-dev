---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import { getCollection } from "astro:content";
const projects = (await getCollection("projects")).sort((a, b) => a.data.priority - b.data.priority);
const baseFilterOrder = ["Professional", "Engine", "C#", "C++", "Tool", "Game", "Unity", "Unreal", "Graphics", "Simulation", "Mobile"];
const discoveredFilters = Array.from(new Set(projects.flatMap((project) => [project.data.type, ...(project.data.tags ?? [])])));
const filters = ["All", ...baseFilterOrder.filter((filter) => discoveredFilters.includes(filter))];
---
<BaseLayout title="Selected work | Pablo Bano Benito">
  <section class="mx-auto max-w-7xl px-5 py-16 sm:px-8">
    <SectionHeading eyebrow="Selected work" title="Project snapshots, with deeper technical breakdowns below." description="The strongest projects are ordered by professional signal: Human Fall Flat 2 for production C# ownership, SufferEngine for C++ systems architecture, and Oona for released Unreal/C++ team delivery." />
    <div class="mb-8 flex flex-wrap gap-3" role="list" aria-label="Project filters">
      {filters.map((filter, index) => (
        <button class="rounded-full border border-slate-900/10 bg-white/55 px-4 py-2 text-sm font-bold text-slate-700 transition hover:border-teal-700/40 data-[active=true]:border-teal-700/50 data-[active=true]:bg-teal-700 data-[active=true]:text-white" data-filter={filter} data-active={index === 0 ? "true" : "false"} aria-pressed={index === 0 ? "true" : "false"}>{filter}</button>
      ))}
    </div>
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">{projects.map((project) => <ProjectCard project={project} />)}</div>
  </section>
  <script is:inline>
    const buttons = Array.from(document.querySelectorAll('[data-filter]'));
    const cards = Array.from(document.querySelectorAll('[data-project-card]'));
    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        const filter = button.getAttribute('data-filter');
        buttons.forEach((item) => {
          const active = item === button;
          item.setAttribute('data-active', String(active));
          item.setAttribute('aria-pressed', String(active));
        });
        cards.forEach((card) => {
          const cardFilters = (card.getAttribute('data-filters') || '').split('|');
          const show = filter === 'All' || cardFilters.includes(filter);
          card.style.display = show ? '' : 'none';
        });
      });
    });
  </script>
</BaseLayout>
