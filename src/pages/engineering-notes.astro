---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { evidenceBlocks, technicalSignals, roleFits } from "../data/profile";
---
<BaseLayout title="Engineering Evidence | Pablo Bano Benito" description="Technical evidence behind Pablo Bañó Benito's C# / C++ software engineering portfolio.">
  <section class="mx-auto max-w-7xl px-5 py-16 sm:px-8">
    <SectionHeading eyebrow="Engineering evidence" title="What is proven, what is private, and what is intentionally not overclaimed." description="This page is the second layer for engineering managers: architecture, debugging, testing, ownership, trade-offs and honest boundaries." />
    <div class="grid gap-5 md:grid-cols-2">
      {evidenceBlocks.map((block) => <article class="panel rounded-[2rem] p-7"><h2 class="text-2xl font-black text-slate-950">{block.title}</h2><p class="mt-4 leading-7 text-slate-600">{block.body}</p></article>)}
    </div>
    <section class="mt-10 panel rounded-[2rem] p-7 sm:p-8">
      <h2 class="text-3xl font-black tracking-tight text-slate-950">Core technical signals</h2>
      <div class="mt-6 grid gap-4 md:grid-cols-2">
        {technicalSignals.map((item) => <div class="rounded-2xl border border-slate-900/10 bg-white/50 p-5"><p class="font-black text-slate-950">{item.title}</p><p class="mt-3 text-sm leading-6 text-slate-600">{item.description}</p></div>)}
      </div>
    </section>
    <section class="mt-10 panel-dark rounded-[2rem] p-7 sm:p-8">
      <h2 class="text-3xl font-black tracking-tight text-white">Claims I avoid over-selling</h2>
      <div class="mt-6 grid gap-4 md:grid-cols-3">
        <div class="rounded-2xl border border-white/10 bg-white/[0.06] p-5"><p class="font-black text-white">Graphics specialist</p><p class="mt-3 text-sm leading-6 text-slate-300">Vulkan/PBR and OpenGL projects show graphics exposure, but the target identity is systems/tools/runtime engineering.</p></div>
        <div class="rounded-2xl border border-white/10 bg-white/[0.06] p-5"><p class="font-black text-white">.NET specialist</p><p class="mt-3 text-sm leading-6 text-slate-300">.NET/backend is a transition path, not a primary claim until more API/cloud/observability evidence exists.</p></div>
        <div class="rounded-2xl border border-white/10 bg-white/[0.06] p-5"><p class="font-black text-white">AI engineer</p><p class="mt-3 text-sm leading-6 text-slate-300">AI is used for exploration, review and productivity, but there is no measured agentic workflow yet.</p></div>
      </div>
    </section>
    <section class="mt-10 panel rounded-[2rem] p-7 sm:p-8">
      <h2 class="text-3xl font-black tracking-tight text-slate-950">Role fit, backed by evidence</h2>
      <div class="mt-6 grid gap-4 md:grid-cols-2 xl:grid-cols-5">{roleFits.map((variant) => <div class="rounded-2xl border border-slate-900/10 bg-white/50 p-5"><p class="font-black text-slate-950">{variant.name}</p><p class="mt-3 text-sm leading-6 text-slate-600">{variant.use}</p><p class="mt-4 text-xs font-black uppercase tracking-[0.18em] text-teal-700">{variant.proof}</p></div>)}</div>
    </section>
  </section>
</BaseLayout>
