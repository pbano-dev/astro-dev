---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { profile } from "../data/profile";
---
<BaseLayout title="Contact | Pablo Bano Benito" description="Contact Pablo Bañó Benito for remote C# / C++ software engineering roles.">
  <section class="mx-auto max-w-5xl px-5 py-16 sm:px-8">
    <SectionHeading eyebrow="Contact" title="Remote C# / C++ software engineering roles." description="Best fit: software engineering, tools, systems, game tech, Unity, C++ engine-adjacent or maintainable interactive software roles. Not interested in crypto or NFT roles." />
    <div class="grid gap-6 md:grid-cols-2">
      <div class="panel rounded-[2rem] p-7 sm:p-8"><h2 class="text-2xl font-black text-slate-950">Reach me</h2><p class="mt-4 text-sm leading-6 text-slate-600">Email is the safest contact channel. I am based in Spain, work remote-only and have EU work authorization.</p><div class="mt-7 flex flex-wrap gap-3"><a href={`mailto:${profile.email}`} class="rounded-full bg-slate-950 px-5 py-2.5 text-sm font-black text-white">Email Pablo</a><a href={profile.cvUrl} class="rounded-full border border-slate-900/15 bg-white/55 px-5 py-2.5 text-sm font-bold text-slate-950">Download CV</a></div></div>
      <div class="panel rounded-[2rem] p-7 sm:p-8"><h2 class="text-2xl font-black text-slate-950">Role fit</h2><ul class="mt-5 grid gap-3 text-sm leading-6 text-slate-700"><li class="rounded-2xl border border-slate-900/10 bg-white/50 p-4">C# / C++ Software Engineer</li><li class="rounded-2xl border border-slate-900/10 bg-white/50 p-4">Tools Engineer / Systems Programmer</li><li class="rounded-2xl border border-slate-900/10 bg-white/50 p-4">Unity Engineer / Game Tech Engineer</li><li class="rounded-2xl border border-slate-900/10 bg-white/50 p-4">Platform-adjacent roles where C#, tooling, debugging and maintainability matter</li></ul></div>
    </div>
  </section>
</BaseLayout>
