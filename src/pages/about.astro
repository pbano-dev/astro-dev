---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { profile, experience, skillGroups, education } from "../data/profile";
---
<BaseLayout title="Profile | Pablo Bano Benito" description={profile.intro}>
  <section class="mx-auto max-w-7xl px-5 py-16 sm:px-8">
    <SectionHeading eyebrow="Profile" title="Architecture, design of software and systems." description="My competitive edge is shipping real work with good architecture: maintainable, testable systems that solve ambiguous runtime problems under production constraints." />
    <div class="grid gap-6 lg:grid-cols-[0.72fr_1.28fr]">
      <aside class="panel-dark rounded-[2rem] p-7 sm:p-8">
        <p class="text-sm font-bold text-teal-200">{profile.location}</p>
        <p class="mt-4 text-sm leading-6 text-slate-300">English professional, Spanish native. Not interested in crypto or NFT roles.</p>
        <div class="mt-7 flex flex-wrap gap-3"><a href={`mailto:${profile.email}`} class="rounded-full bg-white px-5 py-2.5 text-sm font-black text-slate-950">Email</a><a href={profile.cvUrl} class="rounded-full border border-white/15 px-5 py-2.5 text-sm font-bold text-white">Download CV</a></div>
      </aside>
      <div class="panel rounded-[2rem] p-7 sm:p-8">
        <h2 class="text-2xl font-black text-slate-950">Professional engineering experience</h2>
        {experience.map((item) => <div class="mt-6 border-t border-slate-900/10 pt-6"><div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between"><div><h3 class="text-xl font-black text-slate-950">{item.role}</h3><p class="mt-1 text-sm text-slate-600">{item.company}</p></div><p class="text-sm text-slate-500">{item.period}</p></div><p class="mt-4 leading-7 text-slate-600">{item.description}</p><ul class="mt-5 grid gap-3">{item.bullets.map((bullet) => <li class="rounded-2xl border border-slate-900/10 bg-white/50 p-4 text-sm leading-6 text-slate-700">{bullet}</li>)}</ul></div>)}
      </div>
    </div>
    <section class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">{skillGroups.map((group) => <div class="panel rounded-[2rem] p-6"><h3 class="font-black text-slate-950">{group.title}</h3><div class="mt-4 flex flex-wrap gap-2">{group.items.map((item) => <span class="tag">{item}</span>)}</div></div>)}</section>
    <section class="mt-8 panel rounded-[2rem] p-7 sm:p-8"><h2 class="text-2xl font-black text-slate-950">Education</h2><div class="mt-6 grid gap-4 md:grid-cols-2">{education.map((item) => <div class="rounded-3xl border border-slate-900/10 bg-white/50 p-5"><p class="font-black text-slate-950">{item.title}</p><p class="mt-1 text-sm text-slate-600">{item.institution}</p><p class="mt-3 text-sm text-slate-500">{item.period} · {item.detail}</p></div>)}</div></section>
  </section>
</BaseLayout>
