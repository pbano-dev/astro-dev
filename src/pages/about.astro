---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { profile, experience, skillGroups, education } from "../data/profile";
---

<BaseLayout title="About | Pablo Bano Benito" description={profile.intro}>
  <section class="mx-auto max-w-7xl px-5 py-16 sm:px-8">
    <SectionHeading
      eyebrow="About"
      title="Software engineer focused on reliable systems, not just features."
      description={profile.intro}
    />

    <div class="grid gap-6 lg:grid-cols-[0.8fr_1.2fr]">
      <aside class="glass rounded-[2rem] p-7 sm:p-8">
        <p class="text-sm font-semibold text-cyan-200">{profile.location}</p>
        <p class="mt-2 text-sm text-emerald-200">{profile.availability}</p>
        <div class="mt-7 flex flex-wrap gap-3">
          <a href={`mailto:${profile.email}`} class="rounded-full bg-white px-5 py-2.5 text-sm font-black text-slate-950">Email</a>
          <a href={profile.cvUrl} class="rounded-full border border-white/15 px-5 py-2.5 text-sm font-semibold text-white">Download CV</a>
        </div>
      </aside>

      <div class="glass rounded-[2rem] p-7 sm:p-8">
        <h2 class="text-2xl font-black text-white">Professional experience</h2>
        {experience.map((item) => (
          <div class="mt-6 border-t border-white/10 pt-6">
            <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
              <div>
                <h3 class="text-xl font-bold text-white">{item.role}</h3>
                <p class="mt-1 text-sm text-slate-400">{item.company}</p>
              </div>
              <p class="text-sm text-slate-500">{item.period}</p>
            </div>
            <p class="mt-4 leading-7 text-slate-400">{item.description}</p>
            <ul class="mt-5 grid gap-3">
              {item.bullets.map((bullet) => (
                <li class="rounded-2xl border border-white/10 bg-white/[0.035] p-4 text-sm leading-6 text-slate-300">{bullet}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>

    <section class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {skillGroups.map((group) => (
        <div class="glass rounded-[2rem] p-6">
          <h3 class="font-bold text-white">{group.title}</h3>
          <div class="mt-4 flex flex-wrap gap-2">
            {group.items.map((item) => (
              <span class="rounded-full border border-white/10 bg-white/[0.04] px-3 py-1 text-xs text-slate-300">{item}</span>
            ))}
          </div>
        </div>
      ))}
    </section>

    <section class="mt-8 glass rounded-[2rem] p-7 sm:p-8">
      <h2 class="text-2xl font-black text-white">Education</h2>
      <div class="mt-6 grid gap-4 md:grid-cols-2">
        {education.map((item) => (
          <div class="rounded-3xl border border-white/10 bg-white/[0.035] p-5">
            <p class="font-bold text-white">{item.title}</p>
            <p class="mt-1 text-sm text-slate-400">{item.institution}</p>
            <p class="mt-3 text-sm text-slate-500">{item.period} · {item.detail}</p>
          </div>
        ))}
      </div>
    </section>
  </section>
</BaseLayout>
