---
import BaseLayout from "./BaseLayout.astro";
import VideoEmbed from "../components/VideoEmbed.astro";
import MediaFrame from "../components/MediaFrame.astro";

const { project } = Astro.props;
const { title, subtitle, summary, period, role, type, tech, cover, coverAlt, coverPoster, accent, metrics, highlights, links, videoId, gallery } = project.data;
---

<BaseLayout title={`${title} | Pablo Bano Benito`} description={summary}>
  <article class="mx-auto max-w-7xl px-5 py-12 sm:px-8" style={`--project-accent:${accent}`}>
    <a href="/projects" class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.04] px-4 py-2 text-sm text-slate-300 transition hover:border-white/25 hover:text-white">
      ← Back to projects
    </a>

    <header class="mt-10 grid gap-8 lg:grid-cols-[0.95fr_1.05fr] lg:items-end">
      <div>
        <p class="text-xs font-bold uppercase tracking-[0.38em]" style={`color:${accent}`}>{type}</p>
        <h1 class="mt-5 max-w-4xl text-5xl font-black tracking-[-0.07em] text-white sm:text-6xl lg:text-7xl">{title}</h1>
        <p class="mt-6 max-w-3xl text-xl leading-8 text-slate-300">{subtitle}</p>
      </div>

      <div class="glass rounded-[2rem] p-6">
        <div class="grid gap-4 sm:grid-cols-3">
          <div>
            <p class="text-xs uppercase tracking-[0.25em] text-slate-500">Period</p>
            <p class="mt-2 font-bold text-white">{period}</p>
          </div>
          <div>
            <p class="text-xs uppercase tracking-[0.25em] text-slate-500">Role</p>
            <p class="mt-2 font-bold text-white">{role}</p>
          </div>
          <div>
            <p class="text-xs uppercase tracking-[0.25em] text-slate-500">Status</p>
            <p class="mt-2 font-bold text-white">{project.data.status ?? "Selected work"}</p>
          </div>
        </div>
        <div class="mt-5 flex flex-wrap gap-2">
          {tech.map((item) => (
            <span class="rounded-full border border-white/10 bg-white/[0.04] px-3 py-1 text-xs text-slate-300">{item}</span>
          ))}
        </div>
      </div>
    </header>

    <div class="mt-10 overflow-hidden rounded-[2.5rem] border border-white/10 bg-slate-900/70">
      <MediaFrame src={cover} alt={coverAlt} poster={coverPoster} class="max-h-[34rem] w-full object-cover" loading="eager" />
    </div>

    {(metrics.length > 0 || highlights.length > 0 || links.length > 0) && (
      <section class="mt-8 grid gap-6 lg:grid-cols-[0.85fr_1.15fr]">
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-1">
          {metrics.map((metric) => (
            <div class="glass rounded-3xl p-5">
              <p class="text-3xl font-black text-white">{metric.value}</p>
              <p class="mt-2 text-sm text-slate-400">{metric.label}</p>
            </div>
          ))}
        </div>

        <div class="glass rounded-[2rem] p-6 sm:p-8">
          <h2 class="text-2xl font-black text-white">Technical snapshot</h2>
          <p class="mt-3 leading-7 text-slate-400">{summary}</p>

          {highlights.length > 0 && (
            <div class="mt-6 grid gap-3 sm:grid-cols-2">
              {highlights.map((item) => (
                <div class="rounded-2xl border border-white/10 bg-white/[0.035] p-4 text-sm leading-6 text-slate-300">
                  {item}
                </div>
              ))}
            </div>
          )}

          {links.length > 0 && (
            <div class="mt-7 flex flex-wrap gap-3">
              {links.map((link) => (
                <a class="rounded-full border border-white/10 bg-white/[0.04] px-4 py-2 text-sm font-semibold text-white transition hover:border-cyan-300/50" href={link.href}>
                  {link.label} ↗
                </a>
              ))}
            </div>
          )}
        </div>
      </section>
    )}

    {videoId && (
      <section class="mt-12">
        <h2 class="mb-5 text-3xl font-black tracking-tight text-white">Video</h2>
        <VideoEmbed id={videoId} title={`${title} video`} />
      </section>
    )}

    <section class="content-body mt-12">
      <slot />
    </section>

    {gallery.length > 0 && (
      <section class="mt-14">
        <h2 class="mb-6 text-3xl font-black tracking-tight text-white">Gallery</h2>
        <div class="grid gap-5 md:grid-cols-2">
          {gallery.map((item) => (
            <figure class="overflow-hidden rounded-[2rem] border border-white/10 bg-white/[0.035]">
              <MediaFrame src={item.src} alt={item.alt} poster={item.poster} class="h-full w-full object-cover" loading="lazy" />
            </figure>
          ))}
        </div>
      </section>
    )}
  </article>
</BaseLayout>
