---
import BaseLayout from "./BaseLayout.astro";
import VideoEmbed from "../components/VideoEmbed.astro";
import MediaFrame from "../components/MediaFrame.astro";
const { project } = Astro.props;
const {
  title,
  subtitle,
  summary,
  period,
  role,
  type,
  tech = [],
  cover,
  coverAlt,
  coverPoster,
  accent,
  metrics = [],
  highlights = [],
  links = [],
  videoId,
  badges = [],
  gallery = [],
} = project.data ?? {};
---
<BaseLayout title={`${title} | Pablo Bano Benito`} description={summary}>
  <article class="mx-auto max-w-7xl px-5 py-12 sm:px-8" style={`--project-accent:${accent}`}>
    <a href="/projects" class="inline-flex items-center gap-2 rounded-full border border-slate-900/10 bg-white/55 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:border-teal-700/40 hover:text-slate-950">← Back to work</a>

    <header class="mt-10 grid gap-8 lg:grid-cols-[1.05fr_0.95fr] lg:items-end">
      <div>
        <p class="kicker">{type}</p>
        <h1 class="mt-5 max-w-4xl text-5xl font-black tracking-[-0.07em] text-slate-950 sm:text-6xl lg:text-7xl">{title}</h1>
        <p class="mt-6 max-w-3xl text-xl leading-8 text-slate-700">{subtitle}</p>
      </div>
      <aside class="panel rounded-[2rem] p-6">
        <div class="grid gap-4 sm:grid-cols-3">
          <div><p class="text-xs uppercase tracking-[0.22em] text-slate-500">Period</p><p class="mt-2 font-black text-slate-950">{period}</p></div>
          <div><p class="text-xs uppercase tracking-[0.22em] text-slate-500">Role</p><p class="mt-2 font-black text-slate-950">{role}</p></div>
          <div><p class="text-xs uppercase tracking-[0.22em] text-slate-500">Status</p><p class="mt-2 font-black text-slate-950">{project.data.status ?? "Selected work"}</p></div>
        </div>
        <div class="mt-5 flex flex-wrap gap-2">{tech.map((item) => <span class="tag">{item}</span>)}</div>
      </aside>
    </header>

    <div class="mt-10 aspect-video max-h-[34rem] overflow-hidden rounded-[2rem] border border-slate-900/10 bg-slate-900">
      <MediaFrame src={cover} alt={coverAlt} poster={coverPoster} class="h-full w-full object-cover" loading="eager" />
    </div>

    {(metrics.length > 0 || highlights.length > 0 || links.length > 0) && (
      <section class="mt-8 grid gap-6 lg:grid-cols-[0.9fr_1.1fr]">
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-1">
          {metrics.map((metric) => (
            <div class="panel rounded-3xl p-5">
              <p class="text-3xl font-black text-slate-950">{metric.value}</p>
              <p class="mt-2 text-sm text-slate-600">{metric.label}</p>
            </div>
          ))}
        </div>
        <div class="panel rounded-[2rem] p-6 sm:p-8">
          <p class="kicker">Second-layer evidence</p>
          <h2 class="mt-3 text-3xl font-black tracking-tight text-slate-950">Technical snapshot</h2>
          <p class="mt-4 leading-7 text-slate-700">{summary}</p>
          {highlights.length > 0 && <div class="mt-6 grid gap-3 sm:grid-cols-2">{highlights.map((item) => <div class="rounded-2xl border border-slate-900/10 bg-white/50 p-4 text-sm leading-6 text-slate-700">{item}</div>)}</div>}
          {links.length > 0 && <div class="mt-7 flex flex-wrap gap-3">{links.map((link) => <a class="rounded-full border border-slate-900/10 bg-white/55 px-4 py-2 text-sm font-bold text-slate-950 transition hover:border-teal-700/40" href={link.href}>{link.label} ↗</a>)}</div>}
        </div>
      </section>
    )}

    {videoId && <section class="mt-12"><h2 class="mb-5 text-3xl font-black tracking-tight text-slate-950">Video</h2><VideoEmbed id={videoId} title={`${title} video`} /></section>}

    <section class="content-body mt-12 panel rounded-[2rem] p-6 sm:p-10"><slot /></section>

    {gallery.length > 0 && (
      <section class="mt-14">
        <h2 class="mb-5 text-3xl font-black tracking-tight text-slate-950">Gallery</h2>
        {badges.length > 0 && (
          <div class="project-badges-row project-badges-row--under-gallery" aria-label="External links and recognition">
            {badges.map((badge) => (
              badge.href ? (
                <a class="project-badge-link" href={badge.href} aria-label={badge.label ?? badge.alt} target="_blank" rel="noreferrer">
                  <img src={badge.src} alt={badge.alt} class="project-badge-img project-badge-img--button" loading="lazy" />
                </a>
              ) : (
                <figure class="project-badge-static" aria-label={badge.label ?? badge.alt}>
                  <img src={badge.src} alt={badge.alt} class="project-badge-img project-badge-img--award" loading="lazy" />
                </figure>
              )
            ))}
          </div>
        )}
        <div class="grid gap-5 md:grid-cols-2">{gallery.map((item) => <figure class="aspect-video overflow-hidden rounded-[2rem] border border-slate-900/10 bg-white/55"><MediaFrame src={item.src} alt={item.alt} poster={item.poster} class="h-full w-full object-cover" loading="lazy" /></figure>)}</div>
      </section>
    )}

    {gallery.length === 0 && badges.length > 0 && (
      <section class="mt-12">
        <h2 class="mb-5 text-3xl font-black tracking-tight text-slate-950">External links and recognition</h2>
        <div class="project-badges-row">
          {badges.map((badge) => (
            badge.href ? (
              <a class="project-badge-link" href={badge.href} aria-label={badge.label ?? badge.alt} target="_blank" rel="noreferrer">
                <img src={badge.src} alt={badge.alt} class="project-badge-img project-badge-img--button" loading="lazy" />
              </a>
            ) : (
              <figure class="project-badge-static" aria-label={badge.label ?? badge.alt}>
                <img src={badge.src} alt={badge.alt} class="project-badge-img project-badge-img--award" loading="lazy" />
              </figure>
            )
          ))}
        </div>
      </section>
    )}
  </article>
</BaseLayout>
