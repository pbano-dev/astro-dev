---
const { eyebrow, title, description } = Astro.props;
---
<div class="mb-8 max-w-4xl">
  {eyebrow && <p class="kicker">{eyebrow}</p>}
  <h2 class="mt-3 text-4xl font-black tracking-[-0.055em] text-slate-950 sm:text-5xl">{title}</h2>
  {description && <p class="mt-4 max-w-3xl text-lg leading-8 text-slate-600">{description}</p>}
</div>
