---
const { eyebrow, title, description } = Astro.props;
---

<div class="mb-10 max-w-3xl">
  {eyebrow && <p class="mb-4 text-xs font-bold uppercase tracking-[0.35em] text-cyan-300">{eyebrow}</p>}
  <h2 class="text-4xl font-black tracking-tight text-white sm:text-5xl">{title}</h2>
  {description && <p class="mt-5 text-base leading-7 text-slate-400 sm:text-lg">{description}</p>}
</div>
