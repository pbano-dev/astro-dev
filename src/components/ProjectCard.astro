---
import MediaFrame from "./MediaFrame.astro";
const { project, large = false } = Astro.props;
const { title, subtitle, summary, period, tags = [], role, type, tech, cover, coverAlt, coverPoster, accent, metrics } = project.data;
const visibleTags = Array.from(new Set([type, ...tags]));
const href = `/projects/${project.id}`;
---
<a
  href={href}
  data-project-card
  data-type={type}
  data-filters={visibleTags.join("|")}
  class={`group panel relative flex h-full flex-col overflow-hidden rounded-[2rem] transition duration-300 hover:-translate-y-1 hover:shadow-2xl ${large ? "lg:grid lg:grid-cols-[0.95fr_1.05fr]" : ""}`}
  style={`--project-accent:${accent}`}
>
  <div class={`relative overflow-hidden bg-slate-900 ${large ? "aspect-video w-full lg:aspect-auto lg:min-h-[26rem]" : "h-56"}`}>
    <MediaFrame src={cover} alt={coverAlt} poster={coverPoster} class="project-media h-full w-full object-cover transition duration-500 group-hover:scale-[1.035]" loading="lazy" />
    <div class="absolute inset-0 bg-gradient-to-t from-slate-950/70 via-transparent to-transparent"></div>
    <div class="absolute left-4 top-4 flex flex-wrap gap-2">
      {visibleTags.slice(0, 3).map((tag) => <span class="rounded-full bg-white/90 px-3 py-1 text-xs font-bold text-slate-950 shadow-sm">{tag}</span>)}
    </div>
  </div>
  <div class="flex flex-1 flex-col p-6 sm:p-7">
    <div class="mb-5 flex items-center justify-between gap-4 text-xs font-bold uppercase tracking-[0.18em] text-slate-500">
      <span>{period}</span>
      <span>{role}</span>
    </div>
    <h3 class="text-2xl font-black tracking-tight text-slate-950 sm:text-3xl">{title}</h3>
    <p class="mt-3 text-sm font-semibold leading-6 text-slate-700">{subtitle}</p>
    <p class="mt-4 text-sm leading-6 text-slate-600">{summary}</p>
    {metrics.length > 0 && (
      <div class="mt-6 grid grid-cols-2 gap-3">
        {metrics.slice(0, 2).map((metric) => (
          <div class="rounded-2xl border border-slate-900/10 bg-white/55 p-3">
            <p class="text-lg font-black text-slate-950">{metric.value}</p>
            <p class="mt-1 text-xs text-slate-600">{metric.label}</p>
          </div>
        ))}
      </div>
    )}
    <div class="mt-6 flex flex-wrap gap-2">
      {tech.slice(0, large ? 9 : 5).map((item) => <span class="tag">{item}</span>)}
    </div>
    <span class="mt-7 inline-flex text-sm font-black text-teal-700">Open case study →</span>
  </div>
</a>
